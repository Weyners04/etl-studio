# URL du backend FastAPI (optionnel — défaut : http://localhost:8000)
VITE_API_BASE=http://localhost:8000

# Chemins par défaut du job d'exemple affiché au démarrage.
# Copier ce fichier en .env.local et renseigner vos chemins réels.
# .env.local est ignoré par git (ne jamais le committer).
VITE_DEFAULT_INPUT=data/input.csv
VITE_DEFAULT_OUTPUT=data/output.parquet
